# Your Aternos host usually looks like myserver.aternos.me
MC_HOST=your-server.aternos.me
MC_PORT=25565

# Use "offline" for offline/cracked servers.
# Use "microsoft" for a real Microsoft/Minecraft account.
MC_AUTH=offline
MC_USERNAME=AternosBot
MC_PASSWORD=

# Leave blank to let Mineflayer auto-detect the server version.
# If auto-detect fails, set this to your server version, for example 1.20.4
MC_VERSION=

# In-game control. Example: !bot come
COMMAND_PREFIX=!bot

# Comma-separated Minecraft usernames that can command the bot.
# Leave blank only on a private server where you trust everyone.
AUTHORIZED_USERS=YourMinecraftName

# chat or whisper
REPLY_MODE=chat

# Reconnect if the server restarts or kicks the bot.
AUTO_RECONNECT=true
RECONNECT_DELAY_MS=10000

# Let pathfinding break blocks to move around. Keep false unless you trust the bot's route choices.
PATHFINDER_CAN_DIG=false

# Optional: commands sent after spawn, separated by semicolons.
# Useful for servers with an in-game /login plugin.
ON_SPAWN_COMMANDS=

# SecurityLogin/AuthMe-style in-game authentication.
# This sends server commands after the bot spawns. Keep this password secret.
SECURITY_AUTH_ENABLED=false
SECURITY_AUTH_PASSWORD=change-me
SECURITY_AUTH_COMMANDS=/register {password};/login {password}
SECURITY_AUTH_DELAY_MS=3000
SECURITY_AUTH_COMMAND_DELAY_MS=1000

# Automatically accept a server resource pack requirement.
AUTO_ACCEPT_RESOURCE_PACK=true

# Railway supplies PORT automatically. Locally, leave this off unless you want /health.
HEALTH_SERVER_ENABLED=false
HEALTH_PORT=3000
